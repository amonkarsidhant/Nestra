AUTH_JWT_SECRET=replace-with-long-random-secret
CORS_ORIGIN=https://nestra.homelabdev.space
DATABASE_PATH=/data/nestra_demo.db
AUTH_DATABASE_PATH=/data/nestra_auth.db
DEMO_OWNER_USERNAME=owner@nestra.demo
DEMO_OWNER_PASSWORD=nestra-alpha-owner
DEMO_MODE_PUBLIC=true
DEMO_TENANT_ID=default-tenant
DEMO_HOUSEHOLD_ID=default-home
DEMO_ACTOR_ID=owner-1
DEMO_ACTOR_ROLE=owner
LLM_GATEWAY_BASE_URL=http://litellm:4000/v1
LLM_GATEWAY_API_KEY=replace-with-litellm-master-key
LLM_GATEWAY_MODEL_ALIAS=nvidia-fast
LLM_GATEWAY_TIMEOUT_SECONDS=12
STT_BASE_URL=https://integrate.api.nvidia.com/v1
STT_API_KEY=replace-with-nvidia-api-key
STT_MODEL=
STT_TIMEOUT_SECONDS=25
STT_BACKEND=auto
LOCAL_STT_MODEL=tiny
LOCAL_STT_DEVICE=cpu
LOCAL_STT_COMPUTE_TYPE=int8
LOCAL_STT_LANGUAGE=en

# Home Assistant integration (optional)
HA_URL=https://homeassistant.example.com
HA_TOKEN=replace-with-long-lived-access-token
